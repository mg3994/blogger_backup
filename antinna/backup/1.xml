                        <div style='padding: 30px; background: var(--bg-card); border-radius: 16px; border: 1px solid var(--border);'>
                            <h3 style='color: var(--primary); margin-bottom: 1rem;'>Hardware Store</h3>
                            <p>Explore a wide selection of durable tools, equipment, and hardware essentials for every project.</p>
                        </div>
                        <div style='padding: 30px; background: var(--bg-card); border-radius: 16px; border: 1px solid var(--border);'>
                            <h3 style='color: var(--primary); margin-bottom: 1rem;'>Equipment Repair</h3>
                            <p>Expert maintenance and repair for agricultural machinery, power tools, and mechanical gear.</p>
                        </div>
                        <div style='padding: 30px; background: var(--bg-card); border-radius: 16px; border: 1px solid var(--border);'>
                            <h3 style='color: var(--primary); margin-bottom: 1rem;'>Technical Support</h3>
                            <p>Need advice? Our specialists are here to help you choose the right tools and fix complex issues.</p>
                        </div>
                    </div>
                </section>
            </b:if>

            <!-- Main Content (Posts/Pages) -->
            <b:section id='main' name='Main Content' showaddelement='yes'>
                <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog'>
                    <b:includable id='main'>
                        <b:loop values='data:posts' var='post'>
                            <div class='post-body'>
                                <b:if cond='data:view.isSingleItem'>
                                    <h1 style='margin-bottom: 25px; font-weight: 800; border-left: 5px solid var(--primary); padding-left: 15px;'><data:post.title/></h1>
                                </b:if>
                                <data:post.body/>
                            </div>
                        </b:loop>
                    </b:includable>
                </b:widget>
            </b:section>

        </div>
    </div>

    <footer>
        <div class='container'>
            <div class='footer-grid'>
                <div class='footer-brand'>
                    <span class='logo-text'>Antinna</span>
                    <p style='color: var(--text-muted); font-size: 0.95rem; margin-top: 1rem;'>Providing reliable hardware tools and expert machinery repair since 2024.</p>
                </div>
                <div class='footer-links'>
