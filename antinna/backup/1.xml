    <b:skin><![CDATA[

    <Variable name="body_background_color"
            description="Body Background"
            type="color"
            default="#ffffff"
            value="#ffffff"/>
   

    <Group description="Root Theme Color" selector=":root">
      <Variable name="root.primary_color"
        description="Primary Color"
        type="color"
        default="#16a34a"
        value="#16a34a"/>
      <Variable name="root.body_background_color"
        description="Body Background"
        type="color"
        default="#ffffff"
        value="#ffffff"/>
        
    </Group>
  
        :root {
            --primary: $(root.primary_color);
            --primary-hover: #15803d;
            --bg-body: $(root.body_background_color);
            --bg-card: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --glass-bg: rgba(255, 255, 255, 0.95);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            margin: 0; padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            line-height: 1.6;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

        header {
            position: fixed; top: 0; width: 100%; z-index: 1000;
            background: var(--glass-bg); backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
        }

        nav { display: flex; justify-content: space-between; align-items: center; height: 70px; }
        .logo-container { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .logo-img { width: 30px; height: 30px; }
        .logo-text { font-size: 1.4rem; font-weight: 800; color: var(--primary); }

        /* Dynamic Content Area */
        .main-content { padding: 100px 0 60px; min-height: 70vh; }
        .post-body img { max-width: 100%; height: auto; border-radius: 8px; }
        .error-404 { text-align: center; padding: 100px 20px; }
        .error-404 h1 { font-size: 5rem; color: var(--primary); margin: 0; }

        /* Hero only for Homepage */
        .hero { padding: 8rem 0 4rem; text-align: center; background: radial-gradient(circle at top right, #f0fdf4, transparent); }
        .hero h1 { font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 900; margin-bottom: 1rem; color: #064e3b; }
        .hero p { font-size: 1.2rem; color: var(--text-muted); max-width: 700px; margin: 0 auto 2rem; }

        /* Social Widget */
        .social-fixed { position: fixed; bottom: 2rem; right: 2rem; display: flex; flex-direction: column; align-items: flex-end; gap: 8px; z-index: 999; }
        .social-label { background: #1e293b; color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
        .social-icons { display: flex; gap: 8px; background: var(--glass-bg); padding: 8px; border-radius: 12px; border: 1px solid var(--border); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
        .social-icons a { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 8px; background: var(--bg-body); color: var(--text-main); transition: var(--transition); }
        .social-icons a:hover { background: var(--primary); color: white; transform: scale(1.1); }
        
        /* Specialized hover for Colorful Icons to maintain their identity */
        .social-icons a.colorful-icon:hover { background: #f1f5f9; color: initial; }

        footer { padding: 4rem 0 2rem; background: var(--bg-card); border-top: 1px solid var(--border); margin-top: 4rem; }
        .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 3rem; }
        .footer-links h4 { margin-bottom: 1.5rem; font-size: 1.1rem; }
        .footer-links ul { list-style: none; padding: 0; }
        .footer-links li { margin-bottom: 0.8rem; }
        .footer-links a { text-decoration: none; color: var(--text-muted); font-size: 0.95rem; transition: var(--transition); }
        .footer-links a:hover { color: var(--primary); }

        @media (max-width: 768px) {
            .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
            .social-fixed { bottom: 1.5rem; right: 1.5rem; }
        }
    ]]></b:skin>

  

</head>
<body>
    <header>
        <div class='container'>
            <nav>
                <a class='logo-container' href='/'>
